---
import Base from '../layouts/Base.astro';
import { href } from '../components/tokens';
const base = import.meta.env.BASE_URL;
const img = (f: string) => `${base}assets/${f}`;
---
<Base title={'Team · SARA·Detect'} active="team">
  <!-- ===================== PAGE HEADER ===================== -->
    <section style="background: #f7f5f2; border-bottom: 1px solid #e7e3dd;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 72px 40px 64px;">
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #9a1b2a; font-weight: 600; margin-bottom: 20px;">Team</div>
        <h1 style="font-family: 'Spectral', serif; font-weight: 700; font-size: 48px; line-height: 1.08; color: #1a1614; margin: 0 0 20px; max-width: 820px; letter-spacing: -0.015em;">Where animal science meets computer vision</h1>
        <p style="font-size: 17.5px; line-height: 1.62; color: #56504b; margin: 0; max-width: 680px;">A cross-disciplinary collaboration at Southern Illinois University Carbondale, uniting the College of Agricultural Sciences and the School of Computing.</p>
      </div>
    </section>

    <!-- ===================== PRINCIPAL INVESTIGATORS ===================== -->
    <section style="max-width: 1200px; margin: 0 auto; padding: 80px 40px 30px;">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #9a1b2a; font-weight: 600; margin-bottom: 32px;">Principal Investigators</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <!-- PI 1 -->
        <div style="border: 1px solid #e7e3dd; border-radius: 16px; padding: 36px; display: flex; gap: 26px; align-items: flex-start;">
          <div style="flex-shrink:0; width: 88px; height: 88px; border-radius: 14px; background: linear-gradient(140deg,#6e0f1a,#9a1b2a); display:flex; align-items:center; justify-content:center; color:#fff; font-family:'Spectral',serif; font-weight:700; font-size:32px;">AA</div>
          <div>
            <h3 style="font-family:'Spectral',serif; font-weight:700; font-size:24px; color:#1a1614; margin:0 0 4px;">Amer AbuGhazaleh</h3>
            <div style="font-family:'JetBrains Mono',monospace; font-size:11.5px; letter-spacing:0.06em; color:#9a1b2a; margin-bottom:14px;">PRINCIPAL INVESTIGATOR</div>
            <p style="font-size:14.5px; line-height:1.55; color:#56504b; margin:0 0 16px;">Professor, Animal Science · School of Agricultural Sciences, SIU Carbondale. Leads the animal-science side of the project — rumen physiology, fermentation, and acidosis biology.</p>
            <a href="/cdn-cgi/l/email-protection#accdcdced9cbc4cdecdfc5d982c9c8d9" style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#6e0f1a; border-bottom:1px solid #d8b3b0; padding-bottom:2px;" class="maroonlink"><span class="__cf_email__" data-cfemail="cdacacafb8aaa5ac8dbea4b8e3a8a9b8">[email&#160;protected]</span></a>
          </div>
        </div>
        <!-- PI 2 -->
        <div style="border: 1px solid #e7e3dd; border-radius: 16px; padding: 36px; display: flex; gap: 26px; align-items: flex-start;">
          <div style="flex-shrink:0; width: 88px; height: 88px; border-radius: 14px; background: linear-gradient(140deg,#6e0f1a,#9a1b2a); display:flex; align-items:center; justify-content:center; color:#fff; font-family:'Spectral',serif; font-weight:700; font-size:32px;">KA</div>
          <div>
            <h3 style="font-family:'Spectral',serif; font-weight:700; font-size:24px; color:#1a1614; margin:0 0 4px;">Khaled R. Ahmed</h3>
            <div style="font-family:'JetBrains Mono',monospace; font-size:11.5px; letter-spacing:0.06em; color:#9a1b2a; margin-bottom:14px;">CO-PRINCIPAL INVESTIGATOR</div>
            <p style="font-size:14.5px; line-height:1.55; color:#56504b; margin:0 0 16px;">Associate Professor, School of Computing, SIU Carbondale. Directs the computer-vision and deep-learning research — model design, optical gas imaging, and real-time deployment.</p>
            <div style="display:flex; gap:18px; flex-wrap:wrap;">
              <a href="/cdn-cgi/l/email-protection#c0aba8a1aca5a4eea1a8ada5a480b3a9b5eea5a4b5" style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#6e0f1a; border-bottom:1px solid #d8b3b0; padding-bottom:2px;" class="maroonlink"><span class="__cf_email__" data-cfemail="3d56555c515859135c555058597d4e544813585948">[email&#160;protected]</span></a>
              <a href="https://base-lab.org" target="_blank" style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#6e0f1a; border-bottom:1px solid #d8b3b0; padding-bottom:2px;" class="maroonlink">base-lab.org ↗</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== RESEARCHERS ===================== -->
    <section style="max-width: 1200px; margin: 0 auto; padding: 56px 40px 90px;">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #9a1b2a; font-weight: 600; margin-bottom: 32px;">Researchers &amp; Contributors</div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
        <div style="border: 1px solid #e7e3dd; border-radius: 16px; padding: 32px; text-align: center;">
          <div style="margin:0 auto 20px; width: 76px; height: 76px; border-radius: 50%; background: linear-gradient(140deg,#322a25,#544940); display:flex; align-items:center; justify-content:center; color:#f4ede9; font-family:'Spectral',serif; font-weight:700; font-size:27px;">TI</div>
          <h3 style="font-family:'Spectral',serif; font-weight:700; font-size:20px; color:#1a1614; margin:0 0 4px;">Taminul Islam</h3>
          <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.05em; color:#9a1b2a; margin-bottom:12px;">LEAD GRADUATE RESEARCHER</div>
          <p style="font-size:13.5px; line-height:1.5; color:#6b635c; margin:0;">School of Computing · first author on CarboFormer, FUME, and VLMDual.</p>
        </div>
        <div style="border: 1px solid #e7e3dd; border-radius: 16px; padding: 32px; text-align: center;">
          <div style="margin:0 auto 20px; width: 76px; height: 76px; border-radius: 50%; background: linear-gradient(140deg,#322a25,#544940); display:flex; align-items:center; justify-content:center; color:#f4ede9; font-family:'Spectral',serif; font-weight:700; font-size:27px;">TS</div>
          <h3 style="font-family:'Spectral',serif; font-weight:700; font-size:20px; color:#1a1614; margin:0 0 4px;">Toqi Tahamid Sarker</h3>
          <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.05em; color:#9a1b2a; margin-bottom:12px;">GRADUATE RESEARCHER</div>
          <p style="font-size:13.5px; line-height:1.5; color:#6b635c; margin:0;">School of Computing · model development and optical gas imaging experiments.</p>
        </div>
        <div style="border: 1px solid #e7e3dd; border-radius: 16px; padding: 32px; text-align: center;">
          <div style="margin:0 auto 20px; width: 76px; height: 76px; border-radius: 50%; background: linear-gradient(140deg,#322a25,#544940); display:flex; align-items:center; justify-content:center; color:#f4ede9; font-family:'Spectral',serif; font-weight:700; font-size:27px;">ME</div>
          <h3 style="font-family:'Spectral',serif; font-weight:700; font-size:20px; color:#1a1614; margin:0 0 4px;">Mohamed G. Embaby</h3>
          <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.05em; color:#9a1b2a; margin-bottom:12px;">ANIMAL SCIENCE RESEARCHER</div>
          <p style="font-size:13.5px; line-height:1.5; color:#6b635c; margin:0;">Animal Science · rumen fermentation and in-vitro experimental design.</p>
        </div>
      </div>
    </section>

    <!-- ===================== INSTITUTIONS ===================== -->
    <section style="background: #f7f5f2; border-top: 1px solid #e7e3dd;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 64px 40px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
          <div style="background:#fff; border: 1px solid #e7e3dd; border-radius: 14px; padding: 36px 38px;">
            <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.1em; color:#9a1b2a; margin-bottom:12px;">COLLEGE OF AGRICULTURAL SCIENCES</div>
            <h3 style="font-family:'Spectral',serif; font-weight:600; font-size:22px; color:#1a1614; margin:0 0 10px;">Animal Science</h3>
            <p style="font-size:14.5px; line-height:1.58; color:#6b635c; margin:0;">Expertise in ruminant nutrition, rumen physiology, and the biology of subacute ruminal acidosis grounds the project in real animal-health science.</p>
          </div>
          <div style="background:#fff; border: 1px solid #e7e3dd; border-radius: 14px; padding: 36px 38px;">
            <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.1em; color:#9a1b2a; margin-bottom:12px;">SCHOOL OF COMPUTING</div>
            <h3 style="font-family:'Spectral',serif; font-weight:600; font-size:22px; color:#1a1614; margin:0 0 10px;">Computer Vision &amp; AI</h3>
            <p style="font-size:14.5px; line-height:1.58; color:#6b635c; margin:0;">Deep-learning research on semantic segmentation, vision-language models, and efficient real-time inference powers the detection system.</p>
          </div>
        </div>
      </div>
    </section>
</Base>
