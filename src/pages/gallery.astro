---
import Base from '../layouts/Base.astro';
import GalleryGrid from '../components/GalleryGrid.tsx';
---
<Base title={'Gallery · SARA·Detect'} active="gallery">
  <!-- ===================== PAGE HEADER ===================== -->
  <section style="background: #f7f5f2; border-bottom: 1px solid #e7e3dd;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 72px 40px 64px;">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #9a1b2a; font-weight: 600; margin-bottom: 20px;">Gallery</div>
      <h1 style="font-family: 'Spectral', serif; font-weight: 700; font-size: 48px; line-height: 1.08; color: #1a1614; margin: 0 0 20px; max-width: 820px; letter-spacing: -0.015em;">Inside the work</h1>
      <p style="font-size: 17.5px; line-height: 1.62; color: #56504b; margin: 0; max-width: 680px;">Moments from the lab bench, the barn, and the lecture hall. Click any image to enlarge.</p>
    </div>
  </section>

  <GalleryGrid client:load />
</Base>
